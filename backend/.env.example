# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/issue_dashboard

# AI Configuration
AI_PROVIDER=openai
AI_MODEL=openai/open-large
AI_FAST_MODEL=openai/open-fast
AI_API_KEY=your-api-key
AI_API_BASE=https://grid.ai.juspay.net

# Slack Bot (create a separate Slack app for this)
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_APP_TOKEN=xapp-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# App
APP_BASE_URL=http://localhost:8000
DEFAULT_REMINDER_FREQUENCY_MINUTES=120
